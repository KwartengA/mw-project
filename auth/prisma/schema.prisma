generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             Int             @id @default(autoincrement())
  name           String
  email          String          @unique
  role           Role
  affiliation    Affiliation     @default(system)
  isActive       Boolean         @default(true)
  lastLogin      DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  authCredential AuthCredential?
  refreshTokens  RefreshToken[]
}

model AuthCredential {
  id       Int    @id @default(autoincrement())
  userId   Int    @unique
  password String
  user     User   @relation(fields: [userId], references: [id])
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

enum Role {
  admin
  super
}

enum Affiliation {
  police
  fire
  hospital
  system
}
